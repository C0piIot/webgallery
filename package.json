{
  "name": "webgallery",
  "private": true,
  "type": "module",
  "scripts": {
    "lint": "find . \\( -path ./node_modules -o -path ./test-results -o -path ./playwright-report -o -path ./.git \\) -prune -o -name '*.js' -print | xargs -L1 node --check",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "fake-indexeddb": "^6.2.5",
    "vitest": "^4.1.5"
  }
}
